{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "corepack pnpm --filter @router/shared build && corepack pnpm --filter @router/db build && PORT=3001 nest start --watch",
    "start:dev": "corepack pnpm --filter @router/shared build && corepack pnpm --filter @router/db build && nest start --watch",
    "build": "corepack pnpm --filter @router/shared build && corepack pnpm --filter @router/db build && nest build",
    "start": "node dist/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@adyen/api-library": "^30.1.0",
    "@nestjs/common": "^10.4.19",
    "@nestjs/core": "^10.4.19",
    "@nestjs/platform-express": "^10.4.19",
    "@router/db": "workspace:*",
    "@router/shared": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^5.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@multi-psp-router/config": "workspace:*",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.19",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.57",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "test/unit/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@router/db$": "<rootDir>/../../packages/db/src",
      "^@router/shared$": "<rootDir>/../../packages/shared/src"
    },
    "testEnvironment": "node"
  }
}
